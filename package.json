{
  "name": "js-collector",
  "version": "1.0.0",
  "description": "CLI tool to detect and list JavaScript files from URLs for bug bounty, pentesting, and debugging",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "js-collector": "./bin/js-collector.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "start": "tsx src/cli.ts",
    "dev": "tsx src/cli.ts",
    "test": "node --test dist/test/**/*.test.js",
    "test:dev": "tsx --test test/**/*.test.ts"
  },
  "keywords": [
    "javascript",
    "security",
    "bug-bounty",
    "pentesting",
    "cli",
    "crawler"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "csv-stringify": "^6.6.0",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
